{{!
    @template local_faultreporting/faultreports

    Displays a list of fault reports with status, description, user information, and action buttons.
    Shows a message when no reports exist.

    Example context (json):
    {
        "sesskey": "abc123xyz",
        "reportcount": 2,
        "currentpage": 0,
        "totalpages": 1,
        "haspagination": false,
        "pagination": [],
        "reports": [
            {
                "id": 1,
                "userid": 2,
                "user": "John Doe",
                "username": "johndoe",
                "description": "Unable to access course materials",
                "timemodified": 1703001600,
                "status": 1,
                "statusshortcode": "Ok",
                "statusdescription": "Report sent successfully",
                "statusclass": "success",
                "courseid": 1,
                "hasexternalid": true,
                "externalid": "EXT12345",
                "assysteventsearchurl": "https://example.com/search?id=EXT12345",
                "canresend": false
            },
            {
                "id": 2,
                "userid": 3,
                "user": "Jane Smith",
                "username": "janesmith",
                "description": "Error submitting assignment",
                "timemodified": 1703002600,
                "status": 2,
                "statusshortcode": "Error",
                "statusdescription": "Failed to send report",
                "statusclass": "danger",
                "courseid": 1,
                "haserrormessage": true,
                "errormsg": "Connection timeout",
                "canresend": true
            }
        ]
    }
}}
{{^reports}}
<p>{{#str}} noreports, local_faultreporting {{/str}}</p>
{{/reports}}
{{#reportcount}}
<p>{{#str}} reportcount, local_faultreporting, {{reportcount}} {{/str}}</p>
{{/reportcount}}
<ul class="list-group pb-3">
    {{#reports}}
    <li class="list-group-item" data-status-code="{{status}}">
        <div class="w-100">
            <h5 class="mb-1"><span style="font-weight: 500;" class="badge badge-{{statusclass}}">{{statusshortcode}}{{#haserrormessage}} - <i>{{errormsg}}</i>{{/haserrormessage}}</span>{{#showstatusdescription}} <span style="font-weight: 500;" class="badge badge-secondary"><i class="fa fa-info-circle"></i> {{statusdescription}}</span>{{/showstatusdescription}}{{#hasexternalid}} <small>{{#str}} externalid, local_faultreporting {{/str}}: <a target="_blank" href="{{assysteventsearchurl}}">{{externalid}}</a></small>{{/hasexternalid}}</h5>
        </div>
        <hr>
        <h6 class="text-uppercase">Description</h6>
        <p class="mb-1">{{description}}</p>
        <hr>
        <p class="mb-1">
            <small>{{#str}} user, core {{/str}}: <a target="_blank" href="{{globals.config.wwwroot}}/user/profile.php?id={{userid}}">{{user}} ({{username}})</a></small>
        </p>
        <p class="mb-1">
            <small>{{#str}} date, core {{/str}}: {{#userdate}} {{timemodified}}, {{#str}} strftimedate, core_langconfig {{/str}} {{/userdate}}</small>
        </p>
        <div class="d-flex justify-content-end" style="gap: 1em;">
            {{#canresend}}<a class="btn btn-secondary btn-sm" role="button" href="faultreports.php?sesskey={{sesskey}}&courseid={{courseid}}&action=resend&id={{id}}">{{#pix}} t/reload, core, {{#str}} resend, local_faultreporting {{/str}} {{/pix}}{{#str}} resend, local_faultreporting {{/str}}</a>{{/canresend}}
            <a class="btn btn-secondary btn-sm" role="button" href="faultreports.php?sesskey={{sesskey}}&courseid={{courseid}}&action=delete&id={{id}}">{{#pix}} t/delete, core, {{#str}} delete, core {{/str}} {{/pix}}{{#str}} delete, core {{/str}}</a>
        </div>
    </li>
{{/reports}}
</ul>
{{#haspagination}}
<nav aria-label="{{#str}}page, moodle{{/str}}" class="d-flex justify-content-center mt-3 mb-3">
    <ul class="pagination">
        {{#pagination}}
            {{#isprevious}}
            <li class="page-item">
                <a class="page-link page-link-prev" href="faultreports.php?page={{page}}">{{label}}</a>
            </li>
            {{/isprevious}}
            {{#isnumber}}
            <li class="page-item {{#isactive}}active{{/isactive}}">
                <a class="page-link" href="faultreports.php?page={{page}}">{{label}}</a>
            </li>
            {{/isnumber}}
            {{#isnext}}
            <li class="page-item">
                <a class="page-link page-link-next" href="faultreports.php?page={{page}}">{{label}}</a>
            </li>
            {{/isnext}}
        {{/pagination}}
    </ul>
</nav>
{{/haspagination}}
